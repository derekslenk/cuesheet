<Window x:Class="CueSheetMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CueSheet" Height="390" Width="480"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        Background="#FF16161A" FontFamily="Segoe UI" Foreground="#FFE6E6EA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A33"/>
            <Setter Property="Foreground" Value="#FFE6E6EA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Ellipse x:Name="DotSup" Width="12" Height="12" Fill="#FF666670" VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtSup" Margin="10,0,0,0" FontSize="15" FontWeight="SemiBold" Text="Supervisor"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Ellipse x:Name="DotWeb" Width="12" Height="12" Fill="#FF666670" VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtWeb" Margin="10,0,0,0" FontSize="15" FontWeight="SemiBold" Text="Web UI"/>
        </StackPanel>
        <TextBlock x:Name="TxtRelay" Grid.Row="2" Foreground="#FF9A9AA5" Margin="22,0,0,10" Text="relay procs:"/>
        <Border Grid.Row="3" CornerRadius="8" Background="#FF101014" Padding="6">
            <ListView x:Name="ListStreams" Background="Transparent" BorderThickness="0"
                      Foreground="#FFDADAE2" FontFamily="Consolas" FontSize="12"/>
        </Border>
        <UniformGrid Grid.Row="4" Rows="1" Columns="4" Margin="0,12,0,0">
            <Button x:Name="BtnStart" Content="Start" Margin="0,0,6,0" Click="BtnStart_Click"/>
            <Button x:Name="BtnStop" Content="Stop" Margin="3,0,3,0" Click="BtnStop_Click"/>
            <Button x:Name="BtnDash" Content="Dashboard" Margin="3,0,3,0" Click="BtnDash_Click"/>
            <Button x:Name="BtnWeb" Content="Web UI" Margin="6,0,0,0" Click="BtnWeb_Click"/>
        </UniformGrid>
    </Grid>
</Window>
