# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# atomic-write soak runtime files — the harness rewrites these on each
# run; JSON reports go to docs/atomic-write-soak-{strategy}.json explicitly.
docs/atomic-write-soak-tmp/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# VS Code
.vscode/
*.code-workspace

# Local environment variables
.env.local
.env.development.local
.env.test.local
.env.production.local

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Logs
logs
*.log

# ESLint cache
.eslintcache

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Database files (exclude local development databases)
files/*.db
files/*.sqlite
files/*.sqlite3
# But include template database
!files/*.template.db

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp

# Claude Code settings (if you want to keep them private)
.claude/settings.local.json

# cc-sessions runtime files
sessions/sessions-state.json
sessions/package.json
sessions/transcripts/
sessions/.archived/

# OMC runtime + planning artifacts — kept local, NOT committed.
# Plans can contain internal infra notes (hosts, LAN IPs, access details).
.omc/plans/
.omc/state/
.omc/sessions/
.omc/project-memory.json

# obs-scene/ reference data — keep small JSONs + 7 switcher .txt files;
# exclude oversized asset trees, DB mirrors, and generated snapshots.
obs-scene/SaT Summer 2025/
obs-scene/source-switching/sources.db
obs-scene/source-switching/sources.db-*
obs-scene/*.snapshot.*
obs-scene/source-switching/*.snapshot-*

# Serena MCP: agent-local memories/config — keep docs canonical in README/AGENTS.md/CLAUDE.md
.serena/

# Compiled single-executable binaries (npm run supervisor:build* / binary:build*)
dist/
# Release-staging dir for the cuesheet binaries (.github/workflows/release.yml)
release/

# oh-my-claudecode agent working state (plans, handoffs, logs, session state)
.omc/

# Windows WPF monitor build artifacts
monitor/bin/
monitor/obj/

# supervisor / webui runtime logs
*.out.log
*.err.log

# transient bun build --compile artifacts
*.bun-build


# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json

# SQLite WAL sidecar files (created once WAL mode is enabled)
*.db-wal
*.db-shm

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
