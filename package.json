{
  "name": "cuesheet",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "cuesheet": "dist/cuesheet"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --watchAll=false",
    "create-sat-summer-2025-tables": "tsx scripts/createSatSummer2025Tables.ts",
    "add-group-uuid-column": "tsx scripts/addGroupUuidColumn.ts",
    "audit:sqlite-opens": "tsx scripts/auditSqliteOpens.ts",
    "remap:mac-obs-switcher-paths": "tsx scripts/remapMacObsSwitcherPaths.ts",
    "verify:switcher-coverage": "tsx scripts/verifySwitcherCoverage.ts",
    "clean:obs-collection": "tsx scripts/cleanObsCollection.ts",
    "snapshot:phase05": "scripts/capturePhase05Snapshot.sh",
    "measure:switcher-latency": "tsx scripts/measureSwitcherLatency.ts",
    "supervisor": "tsx scripts/streamlink-supervisor/index.ts",
    "supervisor:build": "bun build --compile scripts/streamlink-supervisor/index.bun.ts --outfile dist/supervisor",
    "supervisor:build:win": "bun build --compile --target=bun-windows-x64 scripts/streamlink-supervisor/index.bun.ts --outfile dist/supervisor.exe",
    "cli:dev": "bun run src/cli/main.ts",
    "binary:build": "bun build --compile src/cli/main.ts --outfile dist/cuesheet",
    "binary:build:win": "bun build --compile --target=bun-windows-x64 src/cli/main.ts --outfile dist/cuesheet.exe",
    "binary:build:mac": "bun build --compile --target=bun-darwin-arm64 src/cli/main.ts --outfile dist/cuesheet-macos",
    "binary:build:linux": "bun build --compile --target=bun-linux-x64 src/cli/main.ts --outfile dist/cuesheet-linux",
    "binary:smoke": "node scripts/smokeBinary.mjs",
    "convert:browser-to-media": "tsx scripts/convertBrowserToMedia.ts",
    "loadtest": "tsx scripts/loadtest/index.ts",
    "load:setactive": "tsx scripts/loadDriver.ts",
    "soak:atomic-write": "tsx scripts/atomicWriteSoak.ts",
    "soak:atomic-write:mjs": "node scripts/atomicWriteSoak.mjs"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "commander": "^12.1.0",
    "hls.js": "^1.6.16",
    "next": "^15.4.1",
    "obs-websocket-js": "^5.0.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.4.1",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
