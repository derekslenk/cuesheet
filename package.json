{
  "name": "cuesheet",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.22.3"
  },
  "bin": {
    "cuesheet": "dist/cuesheet"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "type-check:bun": "tsc --noEmit -p tsconfig.bun.json",
    "type-check:deck": "tsc --noEmit -p tsconfig.deck.json",
    "deck": "tsx scripts/streamdeck/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --watchAll=false",
    "import:sheet": "tsx --env-file=.env.local scripts/importFromSheet.ts",
    "create-sat-summer-2025-tables": "tsx scripts/createSatSummer2025Tables.ts",
    "add-group-uuid-column": "tsx scripts/addGroupUuidColumn.ts",
    "add-team-branding-columns": "tsx --env-file=.env.local scripts/addTeamBrandingColumns.ts",
    "setup:test-event": "tsx --env-file=.env.local scripts/setupTestEvent.ts",
    "clone:event": "tsx --env-file=.env.local scripts/cloneEvent.ts",
    "seed:live-test": "tsx --env-file=.env.local scripts/seedLiveTestEvent.ts",
    "event:switch": "tsx --env-file=.env.local scripts/switchEvent.ts",
    "add-disabled-to-streams": "tsx scripts/addDisabledToStreams.ts",
    "audit:sqlite-opens": "tsx scripts/auditSqliteOpens.ts",
    "remap:mac-obs-switcher-paths": "tsx scripts/remapMacObsSwitcherPaths.ts",
    "verify:switcher-coverage": "tsx scripts/verifySwitcherCoverage.ts",
    "clean:obs-collection": "tsx scripts/cleanObsCollection.ts",
    "snapshot:phase05": "scripts/capturePhase05Snapshot.sh",
    "measure:switcher-latency": "tsx scripts/measureSwitcherLatency.ts",
    "supervisor": "tsx scripts/streamlink-supervisor/index.ts",
    "supervisor:build": "bun build --compile scripts/streamlink-supervisor/index.bun.ts --outfile dist/supervisor",
    "supervisor:build:win": "bun build --compile --target=bun-windows-x64 scripts/streamlink-supervisor/index.bun.ts --outfile dist/supervisor.exe",
    "supervisor:build:release": "node scripts/buildSupervisorRelease.mjs",
    "cli:dev": "bun run src/cli/main.ts",
    "binary:build": "bun build --compile src/cli/main.ts --outfile dist/cuesheet",
    "binary:build:win": "bun build --compile --target=bun-windows-x64 src/cli/main.ts --outfile dist/cuesheet.exe",
    "binary:build:mac": "bun build --compile --target=bun-darwin-arm64 src/cli/main.ts --outfile dist/cuesheet-macos",
    "binary:build:linux": "bun build --compile --target=bun-linux-x64 src/cli/main.ts --outfile dist/cuesheet-linux",
    "binary:smoke": "node scripts/smokeBinary.mjs",
    "supervisor:smoke": "node scripts/smokeSupervisorBinary.mjs",
    "convert:browser-to-media": "tsx scripts/convertBrowserToMedia.ts",
    "loadtest": "tsx scripts/loadtest/index.ts",
    "load:setactive": "tsx scripts/loadDriver.ts",
    "soak:atomic-write": "tsx scripts/atomicWriteSoak.ts",
    "soak:atomic-write:mjs": "node scripts/atomicWriteSoak.mjs"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "commander": "^15.0.0",
    "hls.js": "^1.6.16",
    "next": "^16.2.9",
    "obs-websocket-js": "^5.0.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "ws": "^8.21.0"
  },
  "optionalDependencies": {
    "@elgato-stream-deck/node": "^7.6.3",
    "bufferutil": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
